{
  "llvm-target": "loongarch64-unknown-windows",
  "data-layout": "e-m:e-p:64:64-i64:64-i128:128-n32:64-S128",
  "arch": "loongarch64",
  "metadata": {
    "description": "LoongArch64 UEFI (custom JSON target spec mirroring Heiher's Tier-3 proposal)",
    "tier": 3,
    "host_tools": false,
    "std": null
  },
  "target-pointer-width": 64,
  "os": "uefi",
  "panic-strategy": "abort",
  "disable-redzone": true,
  "singlethread": true,
  "stack-probes": {
    "kind": "call"
  },
  "abi-return-struct-as-int": true,
  "emit-debug-gdb-scripts": false,
  "is-like-msvc": true,
  "is-like-windows": true,
  "linker": "rust-lld",
  "linker-flavor": "msvc-lld",
  "linker-is-gnu": false,
  "lld-flavor": "link",
  "pre-link-args": {
    "msvc": [
      "/NOLOGO",
      "/entry:efi_main",
      "/subsystem:efi_application",
      "/machine:loongarch64"
    ],
    "msvc-lld": [
      "/NOLOGO",
      "/entry:efi_main",
      "/subsystem:efi_application",
      "/machine:loongarch64"
    ]
  },
  "entry-name": "efi_main",
  "exe-suffix": ".efi",
  "features": "+f,+d",
  "code-model": "small",
  "cpu": "generic",
  "llvm-abiname": "lp64d",
  "max-atomic-width": 64,
  "direct-access-external-data": true,
  "binary-format": "coff",
  "archive-format": "coff",
  "debuginfo-kind": "pdb",
  "split-debuginfo": "packed",
  "supported-split-debuginfo": ["packed"],
  "dll-tls-export": false,
  "crt-objects-fallback": "false"
}
